    <style>
        /* Doctor Testimonial Banner */
        .doctor-testimonial {
            background: linear-gradient(135deg, #f8f5ff 0%, #fff9f5 100%);
            padding: 30px 20px;
            border-bottom: 2px solid var(--light-beige);
        }
        
        .doctor-testimonial .container {
            max-width: 900px;
        }
        
        .doctor-quote-box {
            background: white;
            padding: 25px 30px;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(76, 34, 166, 0.1);
            border-left: 4px solid var(--primary-purple);
        }
        
        .doctor-quote-text {
            font-size: 17px;
            font-style: italic;
            color: var(--dark-purple);
            line-height: 1.7;
            margin-bottom: 15px;
        }
        
        .doctor-attribution {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }
        
        .doctor-name {
            font-weight: 700;
            color: var(--primary-purple);
            font-size: 16px;
        }
        
        .doctor-title {
            font-size: 14px;
            color: var(--dark-purple);
        }
        
        .doctor-org {
            font-size: 13px;
            color: #666;
        }
        
        @media (min-width: 768px) {
            .doctor-testimonial {
                padding: 40px 20px;
            }
            
            .doctor-quote-box {
                padding: 30px 40px;
            }
            
            .doctor-quote-text {
                font-size: 18px;
            }
        }
    </style>
</head>
<body>
    <!-- Header -->
    <header class="header">
        <div class="container">
