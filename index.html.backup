    <!-- Doctor Testimonial Banner - NEW SECTION AT TOP -->
    <section class="doctor-testimonial">
        <div class="container">
            <div class="doctor-quote-box">
                <p class="doctor-quote-text">"Anugnya equips both patients and caregivers with holistic tools, guidance, and personalized care to navigate through the cancer journey and recovery. This complementary approach helps patients tolerate treatment better and maintain their quality of life."</p>
                <div class="doctor-attribution">
                    <span class="doctor-name">Dr. Chinnababu Sunkavalli</span>
                    <span class="doctor-title">Surgical Oncologist (20+ years)</span>
                    <span class="doctor-org">Clinical Director-Surgical Oncology, Yashoda Hospital</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Hero Section -->
    <section class="hero">
        <div class="container">
